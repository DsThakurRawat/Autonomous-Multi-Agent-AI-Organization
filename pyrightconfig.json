{
  "include": [
    "agents",
    "orchestrator",
    ,
    "tools",
    "utils",
    "api",
    "messaging",
    "observability",
    "tests"
  ],
  "exclude": [
    ".venv",
    "node_modules",
    "dashboard",
    "go-backend",
    ,
    "**/__pycache__"
  ],
  "extraPaths": [
    "."
  ],
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.12",
  "typeCheckingMode": "basic",
  "reportMissingImports": "warning",
  "reportMissingModuleSource": "none",
  "reportOptionalMemberAccess": "warning",
  "reportGeneralTypeIssues": "warning",
  "reportIndexIssue": "none"
}
