# ═══════════════════════════════════════════════════════
# Autonomous Multi-Agent AI Organization — .gitignore
# Works for: Python, Node.js, Rust, TypeScript, Docker
# ═══════════════════════════════════════════════════════

# ── Python ──────────────────────────────────────────────
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover
*.log

# ── Node / TypeScript / Next.js ─────────────────────────
node_modules/
.next/
.nuxt/
out/
dist/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Rust ────────────────────────────────────────────────
target/
Cargo.lock
**/*.rs.bk

# ── Environment / Secrets (NEVER commit these) ──────────
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.cert
*.p12
secrets/
credentials/

# ── Output / Generated per-run (not source code) ────────
output/
generated/
artifacts/

# ── Docker ──────────────────────────────────────────────
*.dockerignore
docker-volumes/

# ── IDE / Editor ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.vim/

# ── OS ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Terraform ───────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
.terraform.lock.hcl
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── K8s / Helm ──────────────────────────────────────────
charts/*.tgz

# ── Jupyter ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
