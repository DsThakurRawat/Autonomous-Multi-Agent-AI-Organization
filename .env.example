# ═══════════════════════════════════════════════════
# AI Organization — Environment Configuration
# Copy this file: cp .env.example .env
# Then fill in your values. NEVER commit .env
# ═══════════════════════════════════════════════════

# ── LLM API Keys ──────────────────────────────────
# At least one required for agents to generate real output
# Without these, agents use structured fallbacks (still works)
OPENAI_API_KEY=sk-...your-key-here...
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Database ──────────────────────────────────────
POSTGRES_PASSWORD=aiorg_secret_2026

# ── System ────────────────────────────────────────
ENVIRONMENT=development
# Options: development | staging | production

# ── Kafka ─────────────────────────────────────────
# Set to "true" to skip Kafka and use in-memory bus (for quick local testing)
KAFKA_MOCK=false

# ── Optional: AWS (only needed for cloud deployment) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ECR_REGISTRY=

# ── Optional: Vector DB ───────────────────────────
# If not set, uses local ChromaDB (no setup needed)
PINECONE_API_KEY=
PINECONE_ENV=

# ── Optional: Grafana ─────────────────────────────
GRAFANA_PASSWORD=ai-org-admin

# ── Port Overrides (optional) ─────────────────────
# Uncomment to use non-default ports
# DASHBOARD_PORT=3000
# API_PORT=8080
# KAFKA_PORT=9092
# KAFKA_UI_PORT=8888
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3002
# JAEGER_UI_PORT=16686
# ORCHESTRATOR_PORT=8081
