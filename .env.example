# ============================================================
# AUTONOMOUS MULTI-AGENT AI ORGANIZATION - Environment Config
# ============================================================

# ── LLM Configuration ──────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-claude-key
AWS_BEDROCK_REGION=us-east-1
# Amazon Nova model ID
AWS_NOVA_MODEL_ID=amazon.nova-pro-v1:0

# ── AWS Configuration ──────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_org
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ai_org

# ── Redis (Short-Term Memory) ──────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── DynamoDB (Long-Term Memory) ────────────────────────────
DYNAMODB_TABLE_PREFIX=ai_org_

# ── S3 (Artifact Storage) ──────────────────────────────────
S3_BUCKET=ai-org-artifacts
S3_REGION=us-east-1

# ── OpenSearch (Vector Memory) ─────────────────────────────
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_INDEX=agent-memory

# ── Application Config ─────────────────────────────────────
APP_ENV=development
APP_PORT=8000
FRONTEND_PORT=3000
SECRET_KEY=your-super-secret-key-change-this

# ── Agent Config ───────────────────────────────────────────
MAX_AGENT_ITERATIONS=10
MAX_SELF_FIX_ATTEMPTS=3
AGENT_TIMEOUT_SECONDS=300
DEFAULT_BUDGET_USD=200

# ── GitHub (Code Repository) ───────────────────────────────
GITHUB_TOKEN=ghp_your-github-token
GITHUB_ORG=your-org
GITHUB_BASE_URL=https://api.github.com

# ── Docker ─────────────────────────────────────────────────
DOCKER_REGISTRY=your-aws-account.dkr.ecr.us-east-1.amazonaws.com

# ── Monitoring ─────────────────────────────────────────────
CLOUDWATCH_LOG_GROUP=/ai-org/agents
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
