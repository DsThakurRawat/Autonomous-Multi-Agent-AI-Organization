# Build Stage
FROM golang:1.24-alpine AS builder

WORKDIR /app
# Install git for fetching dependencies
RUN apk add --no-cache git

# Cache deps
COPY go.mod go.sum ./
RUN go mod download

# Copy source and stubs
COPY . .

# Build standard static binary
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o /go/bin/gateway ./cmd/gateway/

# Final Stage
FROM alpine:latest

# Install runtime dependencies for health checks and HTTPS
RUN apk add --no-cache ca-certificates wget

# Copy the static binary
COPY --from=builder /go/bin/gateway /gateway

# Ensure it binds mapping
EXPOSE 8080

ENTRYPOINT ["/gateway"]

