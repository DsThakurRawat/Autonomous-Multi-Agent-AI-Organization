# Build Stage
FROM golang:1.24-alpine AS builder

WORKDIR /app
RUN apk add --no-cache git

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-w -s" -o /go/bin/orchestrator ./cmd/orchestrator/

# Final Stage
FROM alpine:latest

# Install runtime dependencies for health checks and HTTPS
RUN apk add --no-cache ca-certificates wget \
    && addgroup -S aiorg && adduser -S aiorg -G aiorg

# Copy the static binary
COPY --from=builder --chown=aiorg:aiorg /go/bin/orchestrator /orchestrator

EXPOSE 9090
EXPOSE 9091

# Non-root user (security best practice)
USER aiorg

ENTRYPOINT ["/orchestrator"]

