#!/usr/bin/env python3
"""
Proximus-Nova CLI Launcher
Boots the Amazon Nova powered AI multi-agent platform and Next.js UI locally.
"""

import argparse
import subprocess
import time
import webbrowser
import sys
import os

def print_banner():
    print(r"""
    ____  ____  ____ _  __I__  __  _____  _______
   / __ \/ __ \/ __ \ |/ /_/__/ / / /   |/ __/  /
  / /_/ / /_/ / / / /   / / __  / / / /| |\ \ / / 
 / ____/ _, _/ /_/ /   | / / / / / / / | |_\ \  /  
/_/   /_/ |_|\____/_/|_||_/ /_/\____/  |/____/ /   
                                                   
   PROXIMUS-NOVA - Multi-Agent AI System
=====================================================
    """)

def run_system():
    print("[*] Checking Docker daemon...")
    try:
        subprocess.run(["docker", "info"], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        print("[!] Error: Docker is not running. Please start Docker first.")
        sys.exit(1)

    print("[*] Booting up Proximus-Nova multi-agent platform (Go orchestrator, Rust moe-scoring, Next.js, Agents)...")
    try:
        # Assuming there is a root docker-compose.yml or docker-compose.local.yml
        compose_cmd = ["docker", "compose", "up", "-d", "--build"]
        
        # Check if local compose exists for prioritizing local run
        if os.path.exists("docker-compose.local.yml"):
            compose_cmd = ["docker", "compose", "-f", "docker-compose.local.yml", "up", "-d", "--build"]
            
        subprocess.run(compose_cmd, check=True)
        
        print("\n[*] Native services started successfully!")
    except subprocess.CalledProcessError as e:
        print(f"\n[!] Failed to start services: {e}")
        sys.exit(1)

    print("\n[*] Waiting for Next.js Dashboard to become ready (port 3000)...")
    for _ in range(15):
        try:
            # Simple curl check
            res = subprocess.run(["curl", "-s", "http://localhost:3000"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            if res.returncode == 0:
                break
        except Exception:
            pass
        time.sleep(1)

    print("[*] Proximus-Nova is online.")
    print("[*] Opening physical browser window to the Dashboard...")
    
    # Open dashboard in default browser (using App-mode trick if Chrome is installed, else default tab)
    try:
        webbrowser.open("http://localhost:3000")
    except Exception:
        print("Navigate to http://localhost:3000 in your browser.")
        
    print("\n[+] To safely tear down the platform, run: proximus-nova stop\n")

def stop_system():
    print("[*] Tearing down Proximus-Nova multi-agent platform...")
    compose_cmd = ["docker", "compose", "down"]
    if os.path.exists("docker-compose.local.yml"):
        compose_cmd = ["docker", "compose", "-f", "docker-compose.local.yml", "down"]
        
    subprocess.run(compose_cmd)
    print("\n[*] Offline.")

def main():
    parser = argparse.ArgumentParser(description="Proximus-Nova CLI Launcher")
    parser.add_argument("command", choices=["start", "stop"], help="Action to perform")
    
    args = parser.parse_args()
    
    print_banner()
    
    if args.command == "start":
        run_system()
    elif args.command == "stop":
        stop_system()

if __name__ == "__main__":
    main()
