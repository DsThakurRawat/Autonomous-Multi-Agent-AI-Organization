# ─────────────────────────────────────────────────────────────────────────────
# .env.prod.example — Oracle Cloud Production Environment Template
# Copy to .env on your Oracle VM: cp .env.prod.example .env
# NEVER commit a real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Your Domain ───────────────────────────────────────────────────────────────
# Replace with your actual domain (e.g. ai-org.yourdomain.com)
ORACLE_DOMAIN=ai-org.yourdomain.com

# ── Auth Mode ─────────────────────────────────────────────────────────────────
# false = real Google OAuth login required in production
AUTH_DISABLED=false

# ── LLM API Keys ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── AWS Credentials (for Bedrock if used) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
KEY_ENCRYPTION_KEY=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://ai-org.yourdomain.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://ai-org.yourdomain.com/auth/google/callback

# ── NextAuth secret ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://ai-org.yourdomain.com

# ── JWT Signing Keys ──────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=aiorg
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=aiorg
POSTGRES_PORT=5433

# ── Infrastructure ─────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_ADDR=redis:6379
KAFKA_BROKERS=kafka:29092
QDRANT_PORT=6333

# ── Dashboard (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://ai-org.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://ai-org.yourdomain.com

# ── CORS — allow your dashboard domain ────────────────────────────────────────
CORS_ORIGINS=https://ai-org.yourdomain.com

# ── Observability ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 16
GRAFANA_PASSWORD=CHANGE_ME
ENVIRONMENT=production

# ── Cloudflare Tunnel Token ────────────────────────────────────────────────────
# Get from: Cloudflare Dashboard → Zero Trust → Networks → Tunnels
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
