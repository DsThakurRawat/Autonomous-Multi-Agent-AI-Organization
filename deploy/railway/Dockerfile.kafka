# Standalone Kafka + Zookeeper for Railway
# This uses the bitnami/kafka image which supports KRaft mode (no Zookeeper needed)
# for simpler deployment in container environments.

FROM bitnami/kafka:3.7

ENV KAFKA_ENABLE_KRAFT=yes
ENV KAFKA_CFG_PROCESS_ROLES=broker,controller
ENV KAFKA_CFG_CONTROLLER_LISTENER_NAMES=CONTROLLER
ENV KAFKA_CFG_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
ENV KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
ENV KAFKA_CFG_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
ENV KAFKA_CFG_CONTROLLER_QUORUM_VOTERS=1@localhost:9093
ENV KAFKA_KRAFT_CLUSTER_ID=L6229v_NS7O0B_9rL-02TA
ENV ALLOW_PLAINTEXT_LISTENER=yes
ENV KAFKA_CFG_NODE_ID=1

EXPOSE 9092
